# AMATIS Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# =============================================================================
# Environment
# =============================================================================
AMATIX_ENVIRONMENT=development
AMATIX_DEBUG=true
AMATIX_VERSION=0.1.0

# =============================================================================
# Risk & Trading Mode
# =============================================================================
# CRITICAL: Keep PAPER_MODE=true until explicitly ready for live trading
AMATIX_RISK_PAPER_MODE=true
AMATIX_RISK_KILL_SWITCH_ENABLED=true
AMATIX_RISK_MAX_DAILY_DRAWDOWN=0.025
AMATIX_RISK_MAX_RISK_PER_TRADE=0.02
AMATIX_RISK_MAX_OPEN_POSITIONS=5

# Live mode requires explicit enablement
AMATIX_ENABLE_AUTO_TRADING=false

# =============================================================================
# Data & Persistence
# =============================================================================
# Database (PostgreSQL recommended for production)
AMATIX_DATA_DATABASE_URL=postgresql://user:password@localhost:5432/amatix

# Redis (for caching and state)
AMATIX_DATA_REDIS_URL=redis://localhost:6379/0

# Event store path
AMATIX_DATA_EVENT_STORE_PATH=./event_store
AMATIX_DATA_JOURNAL_ENABLED=true

# =============================================================================
# Broker Connections (fill in only for live/paper trading)
# =============================================================================
# Alpaca
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Use paper for testing

# Interactive Brokers (optional)
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4001
IB_ACCOUNT_ID=your_account_id

# Binance (optional)
BINANCE_API_KEY=your_binance_key_here
BINANCE_SECRET_KEY=your_binance_secret_here

# =============================================================================
# Observability
# =============================================================================
AMATIX_OBS_LOG_LEVEL=INFO
AMATIX_OBS_LOG_FORMAT=json
AMATIX_OBS_METRICS_ENABLED=true
AMATIX_OBS_METRICS_PORT=9090
AMATIX_OBS_TRACING_ENABLED=false
AMATIX_OBS_TRACING_SAMPLE_RATE=0.1

# =============================================================================
# Signal Configuration
# =============================================================================
AMATIX_SIGNAL_MIN_CONFIDENCE=0.80
AMATIX_SIGNAL_ELITE_CONFIDENCE=0.90
AMATIX_SIGNAL_HALF_LIFE_MINUTES=20
AMATIX_SIGNAL_NEWS_POLL_INTERVAL_SECONDS=300

# =============================================================================
# Feature Flags
# =============================================================================
# ML features (enable only when ML infrastructure is ready)
AMATIX_ENABLE_ML=false

# News signals
AMATIX_ENABLE_NEWS_SIGNALS=true

# Price-based signals (enable when data infrastructure is ready)
AMATIX_ENABLE_PRICE_SIGNALS=false
